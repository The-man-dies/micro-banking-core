{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "micro-banking-core",
  "version": "0.1.0",
  "identifier": "com.microbanking.desktop",
  "build": {
    "frontendDist": "../client/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun dev",
    "beforeBuildCommand": "cd client && bun run build && cd ../server && bun compile:linux"
  },
  "app": {
    "windows": [
      {
        "title": "micro-banking-core",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../server/.env",
      "../server/prisma/migrations",
      "resources/schema.prisma",
      "resources/query_compiler_fast_bg.wasm"
    ],
    "externalBin": ["binaries/server"]
  }
}
