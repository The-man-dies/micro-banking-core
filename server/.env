# Application Port
PORT=3001

# Database Configuration
# This is the name of the file that will store our SQLite database.
DATABASE_FILE=micro_banking.db
JWT_SECRET=your_super_secret_and_long_random_string

# JWT Configuration for Access and Refresh Tokens
JWT_ACCESS_TOKEN_SECRET=another_super_secret_for_access
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_SECRET=a_totally_different_and_long_secret_for_refresh
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# ENVIRONMENT
NODE_ENV=development
PRISMA_CLIENT_ENGINE_TYPE="binary"


# This was inserted by `prisma init`:
# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="file:./micro_banking.db"
