{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "bun dist/index.js",
    "dev": "bun --hot src/index.ts",
    "prisma:generate": "bunx prisma generate",
    "build": "bun run prisma:generate && bun build src/index.ts --outdir dist --target=bun",
    "test": "jest",
    "prettier": "prettier --check 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "lint": "eslint 'src/**/*.ts'",
    "create-admin": "bun src/scripts/createAdmin.ts",
    "compile:win": "bun run prisma:generate && bun build ./src/index.ts --compile --target=bun-windows-x64 --outfile=../desktop/binaries/server-x86_64-pc-windows-msvc.exe",
    "compile:linux": "bun run prisma:generate && bun build ./src/index.ts --compile --target=bun-linux-x64-baseline --outfile=../desktop/binaries/server-x86_64-unknown-linux-gnu",
    "compile:mac": "bun run prisma:generate && bun build ./src/index.ts --compile --target=bun-darwin-arm64 --outfile=../desktop/binaries/server-aarch64-apple-darwin"
  },
  "keywords": [],
  "author": "Dioamn keita",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "readline": "^1.3.0",
    "winston": "^3.19.0",
    "zod": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.2",
    "eslint": "^10.0.0",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "prisma": "5.22.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  }
}
